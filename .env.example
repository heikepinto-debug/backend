# ============================================================
# GARAGEHUB API — variáveis de ambiente
# Copiar para .env e preencher com os valores do Supabase
# ============================================================

NODE_ENV=production
PORT=3000

# Supabase (Dashboard → Settings → Database → Connection string, modo "Transaction")
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Supabase (Dashboard → Settings → API)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...  # service_role key (NUNCA expor no frontend)
STORAGE_BUCKET=reception-media

# JWT — gerar: openssl rand -base64 64
JWT_SECRET=SUBSTITUIR_POR_SEGREDO_ALEATORIO
JWT_EXPIRES=8h
JWT_REFRESH_EXPIRES=30d

# CORS — domínio do frontend
CORS_ORIGINS=https://app.garagehub.app,http://localhost:5173
